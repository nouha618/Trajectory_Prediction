class TestPredictHybridLogic:

    @pytest.fixture(autouse=True)
    def setup_model(self, tmp_path, monkeypatch):
        monkeypatch.chdir(tmp_path)
        make_real_rf_model(tmp_path)
        monkeypatch.syspath_prepend(os.path.dirname(os.path.abspath(__file__)))
        if "predict_hybrid" in sys.modules:
            del sys.modules["predict_hybrid"]

    def _state(self, mph=450.0, alt=35000.0, heading=90.0):
        return {"lat": 40.0, "lon": 10.0, "alt": alt,
                "mph": mph, "dt": 600.0,
                "heading_deg": heading, "vertical_speed": 0.0}

    def test_speed_never_below_minimum(self):
        import predict_hybrid as ph
        traj = ph.predict_trajectory_hybrid(self._state(mph=65.0), steps=10)
        for t in traj:
            assert t["mph"] >= ph.MIN_REALISTIC_MPH, \
                f"Vitesse sous le minimum step {t['step']} : {t['mph']:.2f} mph"

    def test_heading_change_bounded(self):
        import predict_hybrid as ph
        traj = ph.predict_trajectory_hybrid(self._state(), steps=15)
        prev = 90.0
        for t in traj:
            delta = abs(((t["heading"] - prev + 180) % 360) - 180)
            assert delta <= ph.MAX_HEADING_CHANGE_DEG + 0.1, \
                f"Cap excessif step {t['step']} : {delta:.2f}°"
            prev = t["heading"]

    def test_altitude_always_positive(self):
        import predict_hybrid as ph
        traj = ph.predict_trajectory_hybrid(self._state(alt=500.0), steps=10)
        for t in traj:
            assert t["alt"] >= 0.0

    def test_trajectory_progresses(self):
        import predict_hybrid as ph
        traj = ph.predict_trajectory_hybrid(self._state(), steps=5)
        assert traj[-1]["lon"] != traj[0]["lon"] or traj[-1]["lat"] != traj[0]["lat"]

    def test_output_structure(self):
        import predict_hybrid as ph
        traj = ph.predict_trajectory_hybrid(self._state(), steps=3)
        assert len(traj) == 3
        for t in traj:
            for key in ["step", "lat", "lon", "alt", "mph", "heading", "cross_track_km"]:
                assert key in t

    def test_seed_state_from_flight(self):
        import predict_hybrid as ph
        df = pd.DataFrame([{
            "flight": "AAL001", "run_id": 0, "lat": 40.0, "long": 10.0,
            "alt": 35000.0, "mph": 480.0, "dt_seconds": 600.0,
            "heading_sin": 0.5, "heading_cos": 0.866,
            "vertical_speed_prev": 1.5, "dt_prev": 600.0,
        }])
        seed = ph.get_seed_state_from_flight(df, "AAL001")
        assert seed["lat"] == pytest.approx(40.0)
        assert seed["mph"] == pytest.approx(480.0)
        assert 0.0 <= seed["heading_deg"] < 360.0

    def test_unknown_flight_raises(self):
        import predict_hybrid as ph
        df = pd.DataFrame([{
            "flight": "AAL001", "run_id": 0, "lat": 40.0, "long": 10.0,
            "alt": 35000.0, "mph": 480.0, "dt_seconds": 600.0,
            "heading_sin": 0.5, "heading_cos": 0.866,
            "vertical_speed_prev": 1.5, "dt_prev": 600.0,
        }])
        with pytest.raises(ValueError):
            ph.get_seed_state_from_flight(df, "VOL_INCONNU")


