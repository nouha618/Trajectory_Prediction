class TestIntegration:

    @pytest.fixture(autouse=True)
    def full_pipeline(self, tmp_path, monkeypatch):
        monkeypatch.chdir(tmp_path)
        make_dummy_dataset(n_flights=20, n_steps=15).to_csv("aircraft_data.csv", index=False)

        base = os.path.dirname(os.path.abspath(__file__))
        import subprocess

        r1 = subprocess.run(
            [sys.executable, os.path.join(base, "prepare_features_rf.py")],
            capture_output=True, text=True
        )
        assert r1.returncode == 0, f"prepare_features_rf.py :\n{r1.stderr}"

        r2 = subprocess.run(
            [sys.executable, os.path.join(base, "train_rf.py")],
            capture_output=True, text=True
        )
        assert r2.returncode == 0, f"train_rf.py :\n{r2.stderr}"

        monkeypatch.syspath_prepend(base)
        if "predict_hybrid" in sys.modules:
            del sys.modules["predict_hybrid"]

    def test_model_files_exist(self):
        assert os.path.exists("rf_residual_model.pkl")
        assert os.path.exists("rf_meta.pkl")

    def test_meta_has_clip_bounds(self):
        meta = joblib.load("rf_meta.pkl")
        assert "clip_bounds" in meta
        for key in ["cross_track_km", "along_track_residual_km", "alt_residual"]:
            assert key in meta["clip_bounds"]

    def test_end_to_end_stable(self):
        import predict_hybrid as ph
        df = pd.read_csv("trajectory_features_rf.csv")
        seed = ph.get_seed_state_from_flight(df, df["flight"].iloc[0])
        traj = ph.predict_trajectory_hybrid(seed, steps=20)

        assert len(traj) == 20
        for t in traj:
            assert t["mph"] >= ph.MIN_REALISTIC_MPH, f"Vitesse trop faible step {t['step']}"
            assert t["mph"] <= ph.MAX_REALISTIC_MPH, f"Vitesse trop haute step {t['step']}"
            assert t["alt"] >= 0, f"Altitude négative step {t['step']}"
            assert 0 <= t["heading"] < 360, f"Cap invalide step {t['step']}"