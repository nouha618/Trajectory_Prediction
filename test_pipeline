class TestHaversine:

    def test_zero_distance(self):
        assert haversine_km(48.8566, 2.3522, 48.8566, 2.3522) == pytest.approx(0.0, abs=1e-6)

    def test_paris_london(self):
        d = haversine_km(48.8566, 2.3522, 51.5074, -0.1278)
        assert 330 < d < 350

    def test_symmetry(self):
        d1 = haversine_km(40.0, 10.0, 45.0, 15.0)
        d2 = haversine_km(45.0, 15.0, 40.0, 10.0)
        assert d1 == pytest.approx(d2, rel=1e-6)

    def test_always_positive(self):
        assert haversine_km(-33.0, 151.0, 35.0, 139.0) > 0

    def test_poles(self):
        d = haversine_km(90, 0, -90, 0)
        assert d == pytest.approx(20015.0, rel=0.01)


class TestBearing:

    def test_north(self):
        assert bearing_deg(0.0, 0.0, 1.0, 0.0) == pytest.approx(0.0, abs=0.5)

    def test_east(self):
        assert bearing_deg(0.0, 0.0, 0.0, 1.0) == pytest.approx(90.0, abs=0.5)

    def test_south(self):
        assert bearing_deg(1.0, 0.0, 0.0, 0.0) == pytest.approx(180.0, abs=0.5)

    def test_west(self):
        assert bearing_deg(0.0, 1.0, 0.0, 0.0) == pytest.approx(270.0, abs=0.5)

    def test_range_0_360(self):
        for lat1, lon1, lat2, lon2 in [
            (48.0, 2.0, 51.0, -0.1),
            (-33.0, 151.0, 35.0, 139.0),
            (40.0, -74.0, 51.0, -0.1),
        ]:
            b = bearing_deg(lat1, lon1, lat2, lon2)
            assert 0.0 <= b < 360.0


class TestDestinationPoint:

    def test_zero_distance(self):
        lat, lon = destination_point(48.8566, 2.3522, 90.0, 0.0)
        assert lat == pytest.approx(48.8566, abs=1e-4)
        assert lon == pytest.approx(2.3522, abs=1e-4)

    def test_north_100km(self):
        lat, lon = destination_point(0.0, 0.0, 0.0, 100.0)
        assert lat == pytest.approx(0.8993, abs=0.01)
        assert lon == pytest.approx(0.0, abs=0.01)

    def test_roundtrip(self):
        """Aller A→B, puis retour B→A avec le VRAI cap sphérique de retour."""
        lat1, lon1 = 48.8566, 2.3522
        lat2, lon2 = destination_point(lat1, lon1, 45.0, 500.0)
        back_bearing = bearing_deg(lat2, lon2, lat1, lon1)  # cap réel, pas +180°
        lat_back, lon_back = destination_point(lat2, lon2, back_bearing, 500.0)
        assert lat_back == pytest.approx(lat1, abs=0.01)
        assert lon_back == pytest.approx(lon1, abs=0.01)

    def test_consistency_with_haversine(self):
        lat1, lon1 = 40.0, 10.0
        dist_req = 250.0
        lat2, lon2 = destination_point(lat1, lon1, 120.0, dist_req)
        assert haversine_km(lat1, lon1, lat2, lon2) == pytest.approx(dist_req, rel=0.001)


class TestCrossAlongTrack:

    def test_on_route_no_cross_track(self):
        lat1, lon1 = 40.0, 10.0
        bearing = 90.0
        lat3, lon3 = destination_point(lat1, lon1, bearing, 100.0)
        cross, along = cross_along_track(lat1, lon1, bearing, lat3, lon3)
        assert cross == pytest.approx(0.0, abs=0.5)
        assert along == pytest.approx(100.0, rel=0.01)

    def test_perpendicular_deviation(self):
        lat1, lon1 = 40.0, 10.0
        lat3, lon3 = destination_point(lat1, lon1, 90.0, 10.0)
        cross, along = cross_along_track(lat1, lon1, 0.0, lat3, lon3)
        assert abs(cross) == pytest.approx(10.0, rel=0.05)
        assert abs(along) < 1.0

    def test_behind_start_negative_along(self):
        lat1, lon1 = 40.0, 10.0
        lat3, lon3 = destination_point(lat1, lon1, 180.0, 50.0)
        cross, along = cross_along_track(lat1, lon1, 0.0, lat3, lon3)
        assert along < 0


