def make_dummy_dataset(n_flights=15, n_steps=15, mph=450, alt=30000):
    """Dataset synthétique en régime de croisière (mph>=250, alt>=10000ft)."""
    rows = []
    rng = np.random.default_rng(42)
    for f in range(n_flights):
        lat, lon = 36.0 + rng.uniform(-2, 2), 10.0 + rng.uniform(-2, 2)
        heading = rng.uniform(0, 360)
        spd = mph + rng.uniform(-20, 20)
        t0 = pd.Timestamp("2022-11-07 12:00:00")
        for step in range(n_steps):
            rows.append({
                "flight": f"TST{f:03d}", "tail_number": f"N{f:05d}",
                "lat": lat, "long": lon,
                "alt": alt + rng.uniform(-50, 50),
                "mph": spd,
                "spotted": (t0 + pd.Timedelta(seconds=600 * step)).strftime("%m/%d/%y %H:%M"),
                "manufacturer": "Boeing", "model": "737",
                "reg_expiration": "2025-01-01", "reg_owner": "TestAir",
                "reg_city": "NYC", "reg_state": "NY", "squawk": 1234,
            })
            dist_km = spd * 1.60934 * (600 / 3600)
            lat, lon = destination_point(lat, lon, heading, dist_km)
            heading = (heading + rng.uniform(-1, 1)) % 360
    return pd.DataFrame(rows)


def make_real_rf_model(tmp_path):
    """Crée un vrai (petit) modèle RF sérialisable par joblib."""
    INPUT_COLS = [
        "lat", "long", "alt", "mph", "dt_seconds",
        "heading_sin", "heading_cos", "vertical_speed_prev", "dt_prev",
    ]
    TARGET_COLS = ["cross_track_km", "along_track_residual_km", "alt_residual"]

    rng = np.random.default_rng(0)
    X = pd.DataFrame(rng.uniform(0, 1, (30, len(INPUT_COLS))), columns=INPUT_COLS)
    y = pd.DataFrame(rng.uniform(-1, 1, (30, 3)), columns=TARGET_COLS)

    rf = RandomForestRegressor(n_estimators=5, max_depth=2, random_state=0)
    rf.fit(X, y)

    meta = {
        "input_cols": INPUT_COLS,
        "target_cols": TARGET_COLS,
        "clip_bounds": {
            "cross_track_km": (-5.0, 5.0),
            "along_track_residual_km": (-50.0, 50.0),
            "alt_residual": (-1000.0, 1000.0),
        }
    }
    joblib.dump(rf, tmp_path / "rf_residual_model.pkl")
    joblib.dump(meta, tmp_path / "rf_meta.pkl")
    return INPUT_COLS, TARGET_COLS


